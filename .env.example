# Copy this file to .env.local (git-ignored) and fill in the values.
#
# VITE_API_URL: base URL of the deployed backend.
# After running `cd backend && sam deploy`, the SAM output prints the URL.
#
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# Cognito — UserPoolId and UserPoolClientId are shown in `sam deploy` Outputs
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Cognito Hosted UI domain for Google OAuth (from sam deploy Outputs > CognitoOAuthDomain)
VITE_COGNITO_DOMAIN=certara-auth.auth.us-east-1.amazoncognito.com

# Qdrant Cloud — used by the indexing script and Lambda functions
QDRANT_URL=https://xxxxxxxx.sa-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
